API_ID=12345678
API_HASH=your_api_hash_here
PANEL_BOT_TOKEN=your_second_bot_token_here
PANEL_OWNER_ID=123456789
# همون دیتابیس MySQL پروژه‌ی اصلی تبچی (Railway) — جداول این پنل جدا هستن
# MYSQLHOST=
# MYSQLPORT=3306
# MYSQLUSER=
# MYSQLPASSWORD=
# MYSQLDATABASE=

# ── پرداخت (فاز ۳) ──
# توکن و یوزرنیم همون ربات اصلی تبچی — چون مشتری با اون ربات /start زده، نه با پنل
TABCI_BOT_TOKEN=your_tabchi_bot_token_here
TABCI_BOT_USERNAME=YourTabchiBotUsername
# مرچنت زرین‌پال خودت (از zarinpal.com بگیر)
ZARINPAL_MERCHANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Railway به این سرویس یه دامنه‌ی عمومی می‌ده؛ callback زرین‌پال باید به این آدرس بیاد:
# https://<railway-domain>/zarinpal/callback
# PORT توسط Railway خودکار ست می‌شه، لازم نیست دستی بدی

# ── محدودیت منابع (فاز ۴) ──
# حداکثر تعداد اکانت تلگرامی فعال که کل سرور تحمل داره (بر اساس رم/CPU پلن Railway).
# مصرف کل به ۷۵٪ و ۹۰٪ این عدد که برسه، هشدار خودکار می‌گیری. 0 = بدون هشدار.
MAX_TOTAL_ACCOUNTS=0
