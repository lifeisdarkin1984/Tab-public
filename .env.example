API_ID=12345678
API_HASH=your_api_hash_here
BOT_TOKEN=your_bot_token_here
# ADMIN_ID دیگه لازم نیست — ربات الان چندمستأجریه و هر کاربر تلگرام با /start
# فضای مستقل خودش رو می‌گیره. فقط اگه از یه نسخه‌ی خیلی قدیمی مهاجرت می‌کنی و
# می‌خوای داده‌های اون ادمین اول رو به سیستم لایه‌بندی migrate کنی، موقتاً ست کن:
# ADMIN_ID=123456789
# Railway MySQL - automatically filled by Railway
# MYSQLHOST=
# MYSQLPORT=3306
# MYSQLUSER=
# MYSQLPASSWORD=
# MYSQLDATABASE=

# ── پرداخت (فاز ۳) ──
# آیدی عددی خودت (owner) — برای دریافت اعلان رسیدهای کارت‌به‌کارت مستقیم تو همین ربات.
# باید حتماً یه‌بار خودت هم /start رو به همین ربات زده باشی وگرنه نمی‌تونه بهت پیام بده.
PANEL_OWNER_ID=123456789
CARD_NUMBER=6037-xxxx-xxxx-xxxx
CARD_HOLDER=نام و نام خانوادگی
# زرین‌پال (اختیاری — اگه خالی بمونه فقط کارت‌به‌کارت فعاله)
ZARINPAL_MERCHANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# آدرس callback باید به سرویس admin_panel (که وب‌سرور callback رو داره) اشاره کنه:
ZARINPAL_CALLBACK_URL=https://<admin-panel-railway-domain>/zarinpal/callback

